<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardExperience"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="10dp"
    android:backgroundTint="@color/bgdark"
    app:cardCornerRadius="16dp"
    android:layout_marginStart="10dp"
    android:layout_marginEnd="10dp"
    app:cardElevation="1dp"
    app:strokeColor="@android:color/transparent"
    app:strokeWidth="0dp"
    >

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <!-- Company Logo -->
        <ImageView
            android:id="@+id/imgCompanyLogo"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:background="@drawable/bg_circle"
            android:contentDescription="Company Logo"
            android:scaleType="centerCrop"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Delete Button -->
        <ImageButton
            android:id="@+id/btnDelete"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Delete Experience"
            android:padding="6dp"
            android:src="@drawable/outline_delete_forever_24"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Designation -->
        <TextView
            android:id="@+id/txtDesignation"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="8dp"
            android:text="Software Engineer"
            android:textColor="@android:color/black"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintStart_toEndOf="@id/imgCompanyLogo"
            app:layout_constraintEnd_toStartOf="@id/btnDelete"
            app:layout_constraintTop_toTopOf="@id/imgCompanyLogo" />

        <!-- Company -->
        <TextView
            android:id="@+id/txtCompany"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="Google"
            app:layout_constraintStart_toStartOf="@id/txtDesignation"
            app:layout_constraintEnd_toEndOf="@id/txtDesignation"
            app:layout_constraintTop_toBottomOf="@id/txtDesignation" />

        <!-- Dates -->
        <TextView
            android:id="@+id/txtdates"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Jan 2022 - Present"
            app:layout_constraintStart_toStartOf="@id/txtDesignation"
            app:layout_constraintEnd_toEndOf="@id/txtDesignation"
            app:layout_constraintTop_toBottomOf="@id/txtCompany" />

        <!-- Description -->
        <TextView
            android:id="@+id/txtDescription"
            android:layout_width="0dp"
            android:layout_height="wrap_content"

            android:ellipsize="end"
            android:gravity="start"
            android:lineSpacingExtra="2dp"
            android:maxLines="5"
            android:text="Worked on Android apps for clients, optimized performance, and collaborated with cross-functional teams across multiple regions..."
            android:textColor="@android:color/black"
            android:textSize="14sp"
            app:layout_constraintStart_toStartOf="@id/txtDesignation"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/txtdates"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>
