<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg"
    tools:context=".home.SearchFragment">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="100dp">

            <androidx.constraintlayout.widget.Guideline
                android:id="@+id/hguide1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                app:layout_constraintGuide_percent="0.02" />

            <androidx.constraintlayout.widget.Guideline
                android:id="@+id/vguide1"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:orientation="vertical"
                app:layout_constraintGuide_percent="0.05" />

            <androidx.constraintlayout.widget.Guideline
                android:id="@+id/vguide2"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:orientation="vertical"
                app:layout_constraintGuide_percent="0.95" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/searchBar"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                app:boxCornerRadiusBottomEnd="10dp"
                app:boxCornerRadiusBottomStart="10dp"
                app:boxBackgroundColor="@color/bgdark"
                app:hintEnabled="false"
                app:boxStrokeWidth="0dp"
                app:startIconDrawable="@drawable/baseline_search_24"
                app:boxCornerRadiusTopStart="10dp"
                app:boxCornerRadiusTopEnd="10dp"

                app:layout_constraintTop_toBottomOf="@+id/hguide1"
                android:layout_marginTop="10dp"
                app:layout_constraintStart_toEndOf="@+id/vguide1"
                app:layout_constraintEnd_toStartOf="@+id/vguide2">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etSearch"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:hint="Search by skill (e.g. Flutter, Node.js)"
                    android:inputType="text"
                    android:imeOptions="actionSearch" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Search Results RV (hidden by default) -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvSearchResults"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:visibility="gone"
                android:layout_marginTop="10dp"
                app:layout_constraintTop_toBottomOf="@id/searchBar"
                app:layout_constraintStart_toEndOf="@id/vguide1"
                app:layout_constraintEnd_toStartOf="@id/vguide2" />

            <!-- HOME CONTENT -->
            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/tvpps"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:layout_constraintTop_toBottomOf="@+id/searchBar"
                app:layout_constraintStart_toEndOf="@id/vguide1"
                android:layout_marginTop="30dp"
                android:text="Popular Project Categories"
                android:textColor="@color/black"
                android:textStyle="bold"
                android:textSize="20sp"
                 />
            <com.facebook.shimmer.ShimmerFrameLayout
                android:id="@+id/skillsShimmer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:layout_constraintTop_toBottomOf="@id/tvpps">

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbars="none">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <include layout="@layout/item_skill_shimmer"/>
                        <include layout="@layout/item_skill_shimmer"/>
                        <include layout="@layout/item_skill_shimmer"/>
                        <include layout="@layout/item_skill_shimmer"/>

                    </LinearLayout>

                </HorizontalScrollView>

            </com.facebook.shimmer.ShimmerFrameLayout>



            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerservices"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                app:layout_constraintStart_toEndOf="@+id/vguide1"
                app:layout_constraintEnd_toStartOf="@+id/vguide2"
                app:layout_constraintTop_toBottomOf="@+id/tvpps"
                android:layout_marginTop="10dp"
                android:orientation="horizontal"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/tvrecent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:layout_constraintTop_toBottomOf="@+id/recyclerservices"
                app:layout_constraintStart_toEndOf="@id/vguide1"
                android:layout_marginTop="30dp"
                android:text="Recent Job/Project Postings"
                android:textColor="@color/black"
                android:textStyle="bold"
                android:textSize="20sp" />



            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerjobs"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                app:layout_constraintStart_toEndOf="@+id/vguide1"
                app:layout_constraintEnd_toStartOf="@+id/vguide2"
                app:layout_constraintTop_toBottomOf="@+id/tvrecent"
                android:layout_marginTop="10dp" />

            <!-- Group to toggle home content visibility -->
            <androidx.constraintlayout.widget.Group
                android:id="@+id/homeContentGroup"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:constraint_referenced_ids="tvpps,recyclerservices,tvrecent,recyclerjobs" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>