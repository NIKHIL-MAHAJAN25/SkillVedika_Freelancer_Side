<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg"
    tools:context=".ClientProfileView.ReviewFragment">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="24dp">

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/hguide1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            app:layout_constraintGuide_percent="0.02" />

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/vguide1"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="vertical"
            app:layout_constraintGuide_percent="0.05" />

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/vguide2"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="vertical"
            app:layout_constraintGuide_percent="0.95" />

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/hguide2"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            app:layout_constraintGuide_percent="0.97" />

        <!-- Back Button -->
        <ImageButton
            android:id="@+id/imgbt"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:backgroundTint="@android:color/transparent"
            android:contentDescription="Back"
            android:src="@drawable/baseline_arrow_back_ios_24"
            app:layout_constraintStart_toEndOf="@id/vguide1"
            app:layout_constraintTop_toBottomOf="@+id/hguide1" />

        <!-- Title -->
        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="Leave a Review"
            android:textColor="@color/black"
            android:textSize="20sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="@id/imgbt"
            app:layout_constraintEnd_toStartOf="@id/vguide2"
            app:layout_constraintStart_toEndOf="@id/imgbt"
            app:layout_constraintTop_toTopOf="@id/imgbt" />

        <!-- Rating Label -->
        <TextView
            android:id="@+id/tvRatingLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Rating"
            android:textColor="@color/black"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toStartOf="@+id/vguide2"
            app:layout_constraintStart_toEndOf="@id/vguide1"
            app:layout_constraintTop_toBottomOf="@id/imgbt" />

        <!-- Star Rating Bar -->
        <RatingBar
            android:id="@+id/ratingBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:numStars="5"
            android:rating="0"
            android:stepSize="1"
            android:progressTint="@color/darkgreen"
            app:layout_constraintStart_toEndOf="@id/vguide1"
            app:layout_constraintEnd_toStartOf="@+id/vguide2"
            app:layout_constraintTop_toBottomOf="@id/tvRatingLabel" />

        <!-- Review Text Label -->
        <TextView
            android:id="@+id/tvReviewLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Review"
            android:textColor="@color/black"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toStartOf="@+id/vguide2"
            app:layout_constraintStart_toEndOf="@id/vguide1"
            app:layout_constraintTop_toBottomOf="@id/ratingBar" />

        <!-- Review Text Input -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tvReviewInput"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:hint="Share your experience working with this client..."
            android:textColorHint="#495048"
            app:boxBackgroundColor="@color/bg"
            app:boxCornerRadiusBottomEnd="10dp"
            app:boxCornerRadiusBottomStart="10dp"
            app:boxCornerRadiusTopEnd="10dp"
            app:boxCornerRadiusTopStart="10dp"
            app:boxStrokeColor="@color/darkgreen"
            app:boxStrokeWidth="1dp"
            app:hintTextColor="@color/darkgreen"
            app:layout_constraintEnd_toStartOf="@+id/vguide2"
            app:layout_constraintStart_toEndOf="@+id/vguide1"
            app:layout_constraintTop_toBottomOf="@+id/tvReviewLabel">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etReview"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="top"
                android:inputType="textMultiLine"
                android:maxLength="300"
                android:minLines="5"
                android:paddingVertical="12dp"
                android:singleLine="false"
                android:textColor="#495048" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Char counter -->
        <TextView
            android:id="@+id/tvCharCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="0/300"
            android:textColor="#999999"
            android:textSize="12sp"
            app:layout_constraintEnd_toStartOf="@id/vguide2"
            app:layout_constraintTop_toBottomOf="@id/tvReviewInput" />

        <!-- Save Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnsave"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:padding="15dp"
            android:text="Submit Review"
            android:textAllCaps="true"
            android:textColor="@color/white"
            app:cornerRadius="10dp"
            app:layout_constraintEnd_toStartOf="@+id/vguide2"
            app:layout_constraintStart_toEndOf="@+id/vguide1"
            app:layout_constraintTop_toBottomOf="@+id/tvCharCount"
            android:backgroundTint="#698B6A" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>