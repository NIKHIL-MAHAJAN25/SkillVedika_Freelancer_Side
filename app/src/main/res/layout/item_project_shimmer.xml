<?xml version="1.0" encoding="utf-8"?>
<com.facebook.shimmer.ShimmerFrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="5.5dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <View
                android:layout_width="4dp"
                android:layout_height="match_parent"
                android:background="#DDDDDD"/>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:padding="14dp">

                <View
                    android:id="@+id/statusShimmer"
                    android:layout_width="70dp"
                    android:layout_height="24dp"
                    android:background="#DDDDDD"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"/>

                <View
                    android:id="@+id/budgetShimmer"
                    android:layout_width="90dp"
                    android:layout_height="18dp"
                    android:background="#DDDDDD"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"/>

                <View
                    android:id="@+id/titleShimmer"
                    android:layout_width="0dp"
                    android:layout_height="20dp"
                    android:layout_marginTop="14dp"
                    android:background="#DDDDDD"
                    app:layout_constraintTop_toBottomOf="@id/statusShimmer"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"/>

                <View
                    android:id="@+id/titleShimmer2"
                    android:layout_width="70dp"
                    android:layout_height="20dp"
                    android:layout_marginTop="6dp"
                    android:background="#DDDDDD"
                    app:layout_constraintTop_toBottomOf="@id/titleShimmer"
                    app:layout_constraintStart_toStartOf="parent"/>

                <View
                    android:id="@+id/descShimmer"
                    android:layout_width="0dp"
                    android:layout_height="16dp"
                    android:layout_marginTop="10dp"
                    android:background="#DDDDDD"
                    app:layout_constraintTop_toBottomOf="@id/titleShimmer2"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"/>

                <View
                    android:id="@+id/descShimmer2"
                    android:layout_width="80dp"
                    android:layout_height="16dp"
                    android:layout_marginTop="6dp"
                    android:background="#DDDDDD"
                    app:layout_constraintTop_toBottomOf="@id/descShimmer"
                    app:layout_constraintStart_toStartOf="parent"/>

                <LinearLayout
                    android:id="@+id/chipsRow"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="horizontal"
                    app:layout_constraintTop_toBottomOf="@id/descShimmer2"
                    app:layout_constraintStart_toStartOf="parent">

                    <View
                        android:layout_width="60dp"
                        android:layout_height="24dp"
                        android:layout_marginEnd="6dp"
                        android:background="#DDDDDD"/>

                    <View
                        android:layout_width="70dp"
                        android:layout_height="24dp"
                        android:layout_marginEnd="6dp"
                        android:background="#DDDDDD"/>

                    <View
                        android:layout_width="50dp"
                        android:layout_height="24dp"
                        android:background="#DDDDDD"/>

                </LinearLayout>

                <View
                    android:id="@+id/divider"
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_marginTop="12dp"
                    android:background="#DDDDDD"
                    app:layout_constraintTop_toBottomOf="@id/chipsRow"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"/>

                <View
                    android:id="@+id/clientShimmer"
                    android:layout_width="120dp"
                    android:layout_height="16dp"
                    android:layout_marginTop="12dp"
                    android:background="#DDDDDD"
                    app:layout_constraintTop_toBottomOf="@id/divider"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"/>

                <View
                    android:id="@+id/buttonShimmer"
                    android:layout_width="90dp"
                    android:layout_height="32dp"
                    android:layout_marginTop="12dp"
                    android:background="#DDDDDD"
                    app:layout_constraintTop_toBottomOf="@id/divider"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"/>

            </androidx.constraintlayout.widget.ConstraintLayout>

            <View
                android:layout_width="4dp"
                android:layout_height="match_parent"
                android:background="#DDDDDD"/>

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

</com.facebook.shimmer.ShimmerFrameLayout>